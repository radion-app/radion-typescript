{
  "name": "@radion-app/sdk",
  "version": "0.6.0",
  "description": "Official SDK for the Radion platform",
  "keywords": [
    "polymarket",
    "prediction-markets",
    "radion",
    "realtime",
    "sdk",
    "websocket"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check": "ultracite check --type-aware --type-check",
    "dev": "tsdown --watch",
    "fix": "ultracite fix --type-aware --type-check",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/ws": "^8.18.1",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "tsdown": "^0.22.4",
    "typescript": "^7.0.2",
    "ultracite": "^7.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
